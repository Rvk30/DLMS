// ============================================================
//  Digital Library Management System — Prisma Schema
//  Database: PostgreSQL  |  ORM: Prisma 5
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────────────────────

/// Role of every user in the system
enum Role {
  STUDENT
  LIBRARIAN
}

/// Current availability state of a physical book copy
enum BookStatus {
  AVAILABLE   // On shelf, can be issued
  ISSUED      // Currently borrowed
  RESERVED    // Reserved by a student but not yet collected
  LOST        // Reported lost
  DAMAGED     // Pulled from circulation for repair
}

/// Genre / subject category
enum BookCategory {
  FICTION
  NON_FICTION
  SCIENCE
  TECHNOLOGY
  MATHEMATICS
  HISTORY
  BIOGRAPHY
  LITERATURE
  ARTS
  PHILOSOPHY
  LAW
  MEDICINE
  REFERENCE
  OTHER
}

/// Lifecycle state of a single borrow transaction
enum TransactionStatus {
  ISSUED    // Book handed to student
  RETURNED  // Book returned on time or late
  OVERDUE   // Due date passed, not yet returned
  LOST      // Student reported book as lost
}

/// Fine settlement state
enum FineStatus {
  PENDING   // Fine accruing, not paid
  PAID      // Student paid the fine
  WAIVED    // Librarian waived the fine
}

/// Membership / account state for a student
enum AccountStatus {
  ACTIVE
  SUSPENDED // e.g. owing too many fines
  EXPIRED
}

// ─────────────────────────────────────────────────────────────
//  USER  (parent of both Student and Librarian)
// ─────────────────────────────────────────────────────────────
model User {
  id                String    @id @default(uuid())
  name              String    @db.VarChar(150)
  email             String    @unique @db.VarChar(255)
  password          String    /// bcrypt hash
  role              Role      @default(STUDENT)
  phone             String?   @db.VarChar(20)
  profileImageUrl   String?

  /// Email verification
  isEmailVerified   Boolean   @default(false)
  emailVerifyToken  String?   @unique
  emailVerifyExpiry DateTime?

  /// Password reset
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?

  /// Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?

  // ── Relations ─────────────────────────────────────────────
  student    Student?    // 1-to-1  (only populated when role=STUDENT)
  librarian  Librarian?  // 1-to-1  (only populated when role=LIBRARIAN)

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
//  STUDENT  (extends User)
// ─────────────────────────────────────────────────────────────
model Student {
  id           String  @id @default(uuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Academic details
  studentId    String  @unique @db.VarChar(30)  // college roll number
  className    String  @db.VarChar(100)          // e.g. "B.Tech CSE – 3rd Year"
  department   String? @db.VarChar(100)
  semester     Int?

  /// Borrow counters (de-normalised for quick checks)
  borrowedCount Int @default(0)   // currently borrowed (max 3)
  reservedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────
  account      Account?
  transactions Transaction[]

  @@index([studentId])
  @@map("students")
}

// ─────────────────────────────────────────────────────────────
//  LIBRARIAN  (extends User)
// ─────────────────────────────────────────────────────────────
model Librarian {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId   String  @unique @db.VarChar(30)
  department   String  @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────
  issuedTransactions   Transaction[] @relation("IssuedBy")
  returnedTransactions Transaction[] @relation("ReturnedBy")
  waivedFines          Fine[]        @relation("WaivedBy")

  @@map("librarians")
}

// ─────────────────────────────────────────────────────────────
//  BOOK
// ─────────────────────────────────────────────────────────────
model Book {
  id              String       @id @default(uuid())
  isbn            String       @unique @db.VarChar(20)
  title           String       @db.VarChar(300)
  author          String       @db.VarChar(200)
  publisher       String       @db.VarChar(200)
  publicationYear Int?
  edition         String?      @db.VarChar(50)
  category        BookCategory @default(OTHER)
  language        String       @default("English") @db.VarChar(50)
  description     String?      @db.Text
  coverImageUrl   String?
  location        String?      @db.VarChar(50) // shelf/rack code, e.g. "A-3-12"

  /// Inventory counts
  totalCopies     Int @default(1)
  availableCopies Int @default(1)

  status          BookStatus @default(AVAILABLE)

  /// Audit
  addedById  String?   // librarian user-id who added the book
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // ── Relations ─────────────────────────────────────────────
  transactions Transaction[]

  @@index([title])
  @@index([author])
  @@index([isbn])
  @@index([category])
  @@map("books")
}

// ─────────────────────────────────────────────────────────────
//  TRANSACTION  (issue / return record)
// ─────────────────────────────────────────────────────────────
model Transaction {
  id             String            @id @default(uuid())

  // ── Parties ──────────────────────────────────────────────
  studentId      String
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Restrict)

  bookId         String
  book           Book       @relation(fields: [bookId], references: [id], onDelete: Restrict)

  issuedById     String?
  issuedBy       Librarian? @relation("IssuedBy",   fields: [issuedById],   references: [id])

  returnedById   String?
  returnedBy     Librarian? @relation("ReturnedBy", fields: [returnedById], references: [id])

  // ── Dates ────────────────────────────────────────────────
  issueDate      DateTime   @default(now())
  dueDate        DateTime                       // issueDate + 14 days (set in service)
  returnDate     DateTime?                      // null until returned

  // ── State ────────────────────────────────────────────────
  status         TransactionStatus @default(ISSUED)

  /// Notes from librarian (e.g. condition on return)
  remarks        String?   @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // ── Relations ─────────────────────────────────────────────
  fine           Fine?

  @@index([studentId])
  @@index([bookId])
  @@index([status])
  @@index([dueDate])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────
//  FINE
// ─────────────────────────────────────────────────────────────
model Fine {
  id              String     @id @default(uuid())

  transactionId   String     @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  studentId       String     // de-normalised for quick queries
  
  /// Calculation
  daysOverdue     Int        @default(0)
  ratePerDay      Decimal    @default(2.00) @db.Decimal(10, 2)  // ₹2/day
  totalAmount     Decimal    @default(0.00) @db.Decimal(10, 2)

  status          FineStatus @default(PENDING)

  /// Payment
  paidAt          DateTime?
  paidAmount      Decimal?   @db.Decimal(10, 2)

  /// Waiver
  waivedById      String?
  waivedBy        Librarian? @relation("WaivedBy", fields: [waivedById], references: [id])
  waivedAt        DateTime?
  waiverReason    String?    @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@map("fines")
}

// ─────────────────────────────────────────────────────────────
//  ACCOUNT  (student library account summary)
// ─────────────────────────────────────────────────────────────
model Account {
  id                  String        @id @default(uuid())
  studentId           String        @unique
  student             Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Running totals
  totalBorrowed       Int     @default(0)  // lifetime borrow count
  totalReturned       Int     @default(0)
  currentlyBorrowed   Int     @default(0)  // active borrows
  totalFineAccrued    Decimal @default(0.00) @db.Decimal(10, 2)
  totalFinePaid       Decimal @default(0.00) @db.Decimal(10, 2)
  outstandingFine     Decimal @default(0.00) @db.Decimal(10, 2)

  membershipExpiry    DateTime?
  status              AccountStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("accounts")
}
