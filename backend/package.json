        "db:seed": "ts-node prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "express": "^4.19.2",
        "cors": "^2.8.5",
        "helmet": "^7.1.0",
        "morgan": "^1.10.0",
        "express-rate-limit": "^7.3.1",
        "express-validator": "^7.1.0",
        "dotenv": "^16.4.5",
        "bcryptjs": "^2.4.3",
        "jsonwebtoken": "^9.0.2",
        "nodemailer": "^6.9.13",
        "@prisma/client": "^5.14.0",
        "crypto": "^1.0.1"
    },
    "devDependencies": {
        "typescript": "^5.4.5",
        "@types/node": "^20.14.2",
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/morgan": "^1.9.9",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/nodemailer": "^6.4.15",
        "ts-node-dev": "^2.0.0",
        "prisma": "^5.14.0"
