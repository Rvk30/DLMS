{
    "name": "dlms-backend",
    "version": "1.0.0",
    "description": "DLMS Backend API",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint 'src/**/*.ts'",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
